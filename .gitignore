# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
.env.local
.env.*.local
*.env

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
build/

# ─── Vite ─────────────────────────────────────────────────────────────────────
*.local

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Keep functions and migrations tracked; ignore local dev state
supabase/.branches/
supabase/.temp/
supabase/config.toml

# Local-only SQL files (may contain credentials)
*.local.sql
supabase/migrations/pg_cron_credentials*.sql

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursor/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ─── Security: never commit keys, certs, credentials ─────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
credentials.json
service-account*.json
*-credentials.json
*secret*
!src/i18n/*.js

